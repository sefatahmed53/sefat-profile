rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // GLOBL HELPERS
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper to identify the administrator
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'sefatahmed53@gmail.com' ||
        request.auth.token.email == 'SefatAhmed53@gmail.com'
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Verification functions for collections
    function isValidProject(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.title is string && data.title.size() <= 150 &&
             data.description is string && data.description.size() <= 1000 &&
             data.category is string && data.category.size() <= 100 &&
             data.role is string && data.role.size() <= 200 &&
             data.year is string && data.year.size() <= 10 &&
             data.imageUrl is string && data.imageUrl.size() <= 2083 &&
             data.tags is list && data.tags.size() <= 20 &&
             data.isFeatured is bool;
    }

    function isValidCertificate(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.title is string && data.title.size() <= 200 &&
             data.issuer is string && data.issuer.size() <= 200 &&
             data.issueDate is string && data.issueDate.size() <= 100 &&
             data.imageUrl is string && data.imageUrl.size() <= 2083 &&
             data.verificationUrl is string && data.verificationUrl.size() <= 2083;
    }

    function isValidReview(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.clientName is string && data.clientName.size() <= 150 &&
             data.clientRole is string && data.clientRole.size() <= 150 &&
             data.clientCompany is string && data.clientCompany.size() <= 150 &&
             data.rating is number && data.rating >= 1 && data.rating <= 5 &&
             data.reviewText is string && data.reviewText.size() <= 3000 &&
             data.date is string && data.date.size() <= 100 &&
             data.approved is bool;
    }

    function isValidContactMessage(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.senderName is string && data.senderName.size() <= 150 &&
             data.senderEmail is string && data.senderEmail.size() <= 150 &&
             data.subject is string && data.subject.size() <= 200 &&
             data.message is string && data.message.size() <= 5000 &&
             data.date is string && data.date.size() <= 100 &&
             data.isRead is bool;
    }

    function isValidSocialLink(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.platform is string && data.platform.size() <= 100 &&
             data.url is string && data.url.size() <= 2083;
    }

    function isValidResume(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.pdfUrl is string && data.pdfUrl.size() <= 2083;
    }

    // RULES MAPPINGS

    // 1. Users collection
    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow list: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    // 2. Projects collection
    match /projects/{projectId} {
      allow read: if true;
      allow create: if isAdmin() && isValidId(projectId) && isValidProject(request.resource.data);
      allow update: if isAdmin() && isValidId(projectId) && isValidProject(request.resource.data);
      allow delete: if isAdmin() && isValidId(projectId);
    }

    // 3. Certificates collection
    match /certificates/{certificateId} {
      allow read: if true;
      allow create: if isAdmin() && isValidId(certificateId) && isValidCertificate(request.resource.data);
      allow update: if isAdmin() && isValidId(certificateId) && isValidCertificate(request.resource.data);
      allow delete: if isAdmin() && isValidId(certificateId);
    }

    // 4. Reviews collection
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isValidId(reviewId) && isValidReview(request.resource.data) && request.resource.data.approved == false;
      allow update: if isAdmin() && isValidId(reviewId) && isValidReview(request.resource.data);
      allow delete: if isAdmin() && isValidId(reviewId);
    }

    // 5. Contact Messages collection
    match /contactMessages/{messageId} {
      allow create: if isValidId(messageId) && isValidContactMessage(request.resource.data) && request.resource.data.isRead == false;
      allow read, update, delete: if isAdmin() && isValidId(messageId);
    }

    // 6. Social Links collection
    match /socialLinks/{socialLinkId} {
      allow read: if true;
      allow create, update, delete: if isAdmin() && isValidId(socialLinkId) && isValidSocialLink(request.resource.data);
    }

    // 7. Resume collection
    match /resume/{resumeId} {
      allow read: if true;
      allow create, update, delete: if isAdmin() && isValidId(resumeId) && isValidResume(request.resource.data);
    }

    // 8. Settings collection
    match /settings/{settingId} {
      allow read: if true;
      allow create, update, delete: if isAdmin() && isValidId(settingId);
    }
  }
}
